# MSSQL Server
mssql.url=jdbc:sqlserver://localhost:1433;databaseName=YourDB
mssql.user=sa
mssql.password=your_password
# 若連線出現 PKIX/SSL 憑證錯誤，設為 true（測試/開發環境常用）
mssql.trustServerCertificate=true

# MySQL
mysql.url=jdbc:mysql://localhost:3306/YourDB?useUnicode=true&characterEncoding=UTF-8
mysql.user=root
mysql.password=your_password

# 每批最多處理筆數（例如 100 或 1000）
batch.size=100

# 測試模式：true 時連 MSSQL 抓資料，只輸出 CSV，不連 MySQL
test.mode=false
# 測試模式時的 CSV 輸出路徑
csv.output=prdt_export.csv

# 記錄上次同步位置的檔案路徑（用 IDX1 作為游標，已處理過的不重複抓）
cursor.path=sync_cursor.txt
